@model FutureTech.StudentManagement.Web.ViewModels.StudentFormViewModel

@{
    ViewData["Title"] = "Add Student";
}

<section class="form-shell">
    <div class="form-shell-inner">
        <div class="form-card">
            <div class="form-card-header">
                <div>
                    <p class="dashboard-kicker">Student Enrolment</p>
                    <h1 class="form-card-title">Add New Student</h1>
                    <p class="form-card-subtitle">Complete all fields and upload a profile image to register a new student.</p>
                </div>
            </div>
            <div class="form-card-body">
                <partial name="_StudentForm" model="Model" />
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
