@model FutureTech.StudentManagement.Web.ViewModels.StudentIndexViewModel

@{
    ViewData["Title"] = "Student Management Dashboard";
}

<section class="dashboard-shell high-density-shell">
    <div class="density-header-bar">
        <div class="density-branding">
            <img src="@Url.Content("~/images/FTechLogo.png")" alt="FutureTech Academy" class="density-brand-logo" />
            <div>
                <p class="density-brand-kicker">Student Intelligence Panel</p>
                <h1 class="density-brand-title">Administrator Dashboard</h1>
                <p class="density-brand-subtitle">High-density monitoring view for secure student lifecycle operations.</p>
            </div>
        </div>
        <a class="btn density-primary-btn" asp-action="Create">Add Student</a>
    </div>

    @if (TempData["Success"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert density-alert-success">@successMessage</div>
    }

    <div class="density-kpi-grid">
        <article class="density-kpi-card">
            <p class="density-kpi-label">Active Students</p>
            <p class="density-kpi-value">@Model.ActiveCount</p>
            <p class="density-kpi-meta density-positive">@Model.ActiveRate.ToString("0.0")% active rate</p>
        </article>
        <article class="density-kpi-card">
            <p class="density-kpi-label">Marked Inactive</p>
            <p class="density-kpi-value">@Model.InactiveCount</p>
            <p class="density-kpi-meta">Soft + inactive states</p>
        </article>
        <article class="density-kpi-card">
            <p class="density-kpi-label">Soft Deleted</p>
            <p class="density-kpi-value">@Model.SoftDeletedCount</p>
            <p class="density-kpi-meta">Recoverable records</p>
        </article>
        <article class="density-kpi-card">
            <p class="density-kpi-label">Permanent Deletes</p>
            <p class="density-kpi-value">@Model.PermanentlyDeletedCount</p>
            <p class="density-kpi-meta">Since app start</p>
        </article>
        <article class="density-kpi-card">
            <p class="density-kpi-label">Profiles With Images</p>
            <p class="density-kpi-value">@Model.WithImageCount</p>
            <p class="density-kpi-meta">Profile completeness</p>
        </article>
        <article class="density-kpi-card">
            <p class="density-kpi-label">New This Week</p>
            <p class="density-kpi-value">@Model.NewThisWeekCount</p>
            <p class="density-kpi-meta density-positive">+7 day intake</p>
        </article>
    </div>

    <section class="density-table-panel">
        <div class="density-table-header">
            <div>
                <h2>Student Records</h2>
                <p>Compact operational view for student status, identity, and enrollment auditing.</p>
            </div>
            <form asp-action="EnrolledStudents" method="get" class="density-filter-form" role="search" aria-label="Filter student records">
                <input type="text" name="query" class="density-filter-input" placeholder="Search by name, surname, or ID" />
                <button type="submit" class="btn density-primary-btn">Search</button>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table density-data-table align-middle mb-0" aria-label="Student data grid">
                <thead>
                    <tr>
                        <th>Student ID</th>
                        <th>Full Name</th>
                        <th>Email Address</th>
                        <th>Enrollment Status</th>
                        <th>Date Enrolled</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Students.Any())
                    {
                        <tr>
                            <td colspan="5" class="density-empty-cell">No student records available.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var student in Model.Students)
                        {
                            var fullName = string.Concat(student.FirstName, " ", student.LastName).Trim();
                            var active = student.EnrolmentStatus.Equals("Active", StringComparison.OrdinalIgnoreCase) && !student.IsSoftDeleted;
                            var badgeClass = active ? "density-status-badge status-active" : "density-status-badge status-inactive";
                            var statusText = active ? "Active" : "Inactive";

                            <tr>
                                <td class="density-id-cell">@student.Id</td>
                                <td class="density-name-cell">@fullName</td>
                                <td>@student.Email</td>
                                <td>
                                    <span class="@badgeClass">@statusText</span>
                                </td>
                                <td>@student.DateEnrolledUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="density-table-footer">
            <a class="btn density-outline-btn" asp-action="EnrolledStudents">Open Enrolled Students</a>
        </div>
    </section>
</section>
