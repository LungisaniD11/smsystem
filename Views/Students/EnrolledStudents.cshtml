@model FutureTech.StudentManagement.Web.ViewModels.StudentIndexViewModel

@{
    ViewData["Title"] = "Enrolled Students";
}

<section class="dashboard-shell enrolled-shell">
    <div class="density-header-bar enrolled-header-bar">
        <div>
            <p class="density-brand-kicker">Student Directory</p>
            <h1 class="density-brand-title">Enrolled Students</h1>
            <p class="density-brand-subtitle">Browse detailed student cards and manage enrolment records with lifecycle actions.</p>
        </div>
        <div class="density-header-actions d-flex gap-2 flex-wrap">
            <a class="btn density-outline-btn" asp-action="Index">Back to Dashboard</a>
            <a class="btn density-primary-btn" asp-action="Create">Add Student</a>
        </div>
    </div>

    @if (TempData["Success"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert density-alert-success">@successMessage</div>
    }

    <section class="density-table-panel enrolled-density-panel">
        <div class="density-table-header">
            <div>
                <h2>Student Cards</h2>
                <p>Photo, contact details, enrolment status and record actions per student.</p>
            </div>
            <form method="get" class="density-filter-form" role="search" aria-label="Search enrolled students">
                <input type="text" name="query" value="@Model.SearchQuery" class="density-filter-input" placeholder="Search by student name, surname, or ID" aria-label="Search students" />
                <button type="submit" class="btn density-primary-btn">Search</button>
                <a asp-action="EnrolledStudents" class="btn density-outline-btn">Clear</a>
            </form>
        </div>

        @if (!Model.Students.Any())
        {
            <div class="density-empty-cell py-4 text-center">No students found for this filter.</div>
        }
        else
        {
            <div class="enrolled-cards-grid">
                @foreach (var student in Model.Students)
                {
                    var fullName = string.Concat(student.FirstName, " ", student.LastName).Trim();
                    var initials = string.Concat(
                        student.FirstName.Length > 0 ? student.FirstName[0].ToString() : "",
                        student.LastName.Length > 0 ? student.LastName[0].ToString() : ""
                    ).ToUpperInvariant();
                    var isActive = student.EnrolmentStatus.Equals("Active", StringComparison.OrdinalIgnoreCase) && !student.IsSoftDeleted;
                    var statusText = isActive ? "Active" : "Inactive";
                    var statusClass = isActive ? "density-status-badge status-active" : "density-status-badge status-inactive";

                    <article class="enrolled-card" aria-label="Student card for @fullName">
                        <div class="enrolled-card-top">
                            @if (!string.IsNullOrWhiteSpace(student.ProfileImageSasUrl))
                            {
                                <img src="@student.ProfileImageSasUrl" alt="@fullName profile photo" class="enrolled-card-avatar" />
                            }
                            else
                            {
                                <div class="enrolled-card-avatar-placeholder" aria-hidden="true">@initials</div>
                            }
                            <div class="enrolled-card-identity">
                                <div class="enrolled-card-name">@fullName</div>
                                <div class="enrolled-card-email">@student.Email</div>
                                <div class="enrolled-card-id" title="@student.Id">@student.Id</div>
                            </div>
                        </div>

                        <div class="enrolled-card-meta-row">
                            <div class="enrolled-card-detail-item">
                                <span class="enrolled-card-detail-label">Mobile</span>
                                <span class="enrolled-card-detail-value">@student.MobileNumber</span>
                            </div>
                            <div class="enrolled-card-detail-item">
                                <span class="enrolled-card-detail-label">Enrolled</span>
                                <span class="enrolled-card-detail-value">@student.DateEnrolledUtc.ToLocalTime().ToString("yyyy-MM-dd")</span>
                            </div>
                            <div class="enrolled-card-detail-item">
                                <span class="enrolled-card-detail-label">Status</span>
                                <div class="mt-1">
                                    <span class="@statusClass">@statusText</span>
                                    @if (student.IsSoftDeleted)
                                    {
                                        <span class="density-status-badge status-soft-deleted ms-1">Soft Deleted</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="enrolled-card-actions">
                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm density-primary-btn enrolled-card-action-btn">Edit</a>

                            <form asp-action="SoftDelete" method="post" onsubmit="return confirm('Mark this student as inactive?');" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@student.Id" />
                                <button type="submit" class="btn btn-sm enrolled-soft-delete-btn enrolled-card-action-btn">Soft Delete</button>
                            </form>

                            <form asp-action="PermanentDelete" method="post" onsubmit="return confirm('Permanently delete this student record?');" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@student.Id" />
                                <button type="submit" class="btn btn-sm enrolled-delete-btn enrolled-card-action-btn">Delete</button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Students pagination" class="mt-4">
            <ul class="pagination dashboard-pagination">
                @for (var currentPage = 1; currentPage <= Model.TotalPages; currentPage++)
                {
                    <li class="page-item @(currentPage == Model.PageNumber ? "active" : string.Empty)">
                        <a class="page-link" asp-action="EnrolledStudents" asp-route-query="@Model.SearchQuery" asp-route-page="@currentPage">@currentPage</a>
                    </li>
                }
            </ul>
        </nav>
    }
</section>
